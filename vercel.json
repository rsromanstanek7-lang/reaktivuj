{
  "cleanUrls": true,
  "trailingSlash": false,
  "rewrites": [
    {
      "source": "/(.*)",
      "has": [{ "type": "host", "value": "kalkulator.reaktivuj.cz" }],
      "destination": "/kalkulator.html"
    },
    {
      "source": "/dekujeme",
      "destination": "/dekujeme.html"
    },
    {
      "source": "/blog",
      "destination": "/blog/index.html"
    }
  ]
}
